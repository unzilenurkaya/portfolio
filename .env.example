# Core site configuration
# Update these values for your environment before deploying

# Public site URL used by SEO metadata, sitemap and robots
NEXT_PUBLIC_SITE_URL=https://unzilenurkaya.com

# Email delivery for the contact form
# If omitted, the API returns success in development mode without sending an email
# RESEND_API_KEY=re_xxxxxxxxx

# Google Search Console verification (optional)
# GOOGLE_SITE_VERIFICATION=your-verification-code

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# AI assistant (optional)
# Gemini API key for the on-site assistant
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash-lite

# OpenRouter fallback (optional)
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
